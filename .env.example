# --- Option A: Gmail SMTP (recommended for amol.eng@gmail.com) ---
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=amol.eng@gmail.com
SMTP_PASS=your_gmail_app_password_here
FROM_EMAIL=amol.eng@gmail.com
TO_EMAIL=amol.eng@gmail.com

# --- Option B: SendGrid (uncomment and fill if you prefer SendGrid) ---
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your_api_key_here
# FROM_EMAIL=verified-sender@yourdomain.com
# TO_EMAIL=amol.eng@gmail.com

# Optional: timezone for report timestamps (default Asia/Kolkata)
DIGEST_TIMEZONE=Asia/Kolkata

# --- WhatsApp (CallMeBot) — message yourself ---
# 1. Add bot +34 644 53 78 49 as a phone contact (Spain +34)
# 2. Open WhatsApp chat with that contact
# 3. Send: I allow callmebot to send me messages
# 4. Save the apikey they reply with below
# Docs: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=919604423793
WHATSAPP_APIKEY=your_callmebot_apikey_here

# Optional: set to 1 to send a live email during smoke tests
SEND_LIVE_EMAIL=0
